[client-server.#NODE_SECTION#]
port                    = 33#NODE_ID#6
socket                  = /run/mariadb-multi/#NODE#.sock

[mariadb.#NODE_SECTION#]
user                    = mysql
pid_file                = /run/mariadb-multi/#NODE#.pid
datadir                 = /var/lib/mariadb-multi/#NODE#
log_bin                 = /var/log/mariadb-multi/#NODE#/mysql-bin.log
log_error               = /var/log/mariadb-multi/#NODE#/error.log
log_basename            = #NODE#
server_id               = 1#NODE_ID#
performance_schema      = on
rpl_semi_sync_master_enabled = 1
rpl_semi_sync_slave_enabled = 1
replicate-wild-ignore-table = %.unittest_%
innodb_print_all_deadlocks = on
