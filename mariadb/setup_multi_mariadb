#!/bin/bash

REAL_PATH=$(realpath "$0")
BASE_DIR=$(dirname "$REAL_PATH")
NODES=("db1 db2 db3 db4")

if [ "$1" == "init" ]; then
  RESET=0;
elif [ "$1" == "reset" ]; then
  RESET=1;
else
  echo 'Usage: setup_multi_mariadb [init|reset]'
  exit 1
fi

cd ~

for NODE in $NODES; do
  echo "Unregistering/stopping any prior ${NODE} service..."
  sudo systemctl stop "mariadb@${NODE}.service"
  sudo systemctl disable "mariadb@${NODE}.service"
done

echo 'Setting base directories...'
if [ ! -d "/etc/mariadb-multi" ]; then
  sudo mkdir "/etc/mariadb-multi" || exit $?
fi
if [ ! -d "/var/lib/mariadb-multi" ]; then
  sudo mkdir "/var/lib/mariadb-multi" || exit $?
  sudo chown -R mysql:mysql "/var/lib/mariadb-multi" || exit $?
fi
if [ ! -d "/var/log/mariadb-multi" ]; then
  sudo mkdir -m 0775 "/var/log/mariadb-multi" || exit $?
  sudo chown -R mysql:adm "/var/log/mariadb-multi" || exit $?
fi
if [ ! -d "/run/mariadb-multi" ]; then
  sudo mkdir "/run/mariadb-multi" || exit $?
  sudo chown -R mysql:mysql "/run/mariadb-multi" || exit $?
fi
if [ ! -f "/usr/lib/tmpfiles.d/mariadb-multi.conf" ]; then
  # Create temporary /var/run directory on boot
  echo "d /run/mariadb-multi 0755 mysql mysql  -" | sudo tee "/etc/tmpfiles.d/mariadb-multi.conf"
fi
for NODE in $NODES; do
  if [ $RESET -eq 1 ]; then
    echo "Removing ${NODE} data directories"
    sudo rm -rf "/var/lib/mariadb-multi/${NODE}" || exit $?
    sudo rm -rf "/var/log/mariadb-multi/${NODE}" || exit $?
  fi
  if [ ! -d "/var/lib/mariadb-multi/${NODE}" ]; then
    echo "Setting ${NODE} data directory"
    sudo mkdir -m 0775 "/var/lib/mariadb-multi/${NODE}" || exit $?
    sudo chown -R mysql:mysql "/var/lib/mariadb-multi/${NODE}" || exit $?
  fi
  if [ ! -d "/var/log/mariadb-multi/${NODE}" ]; then
    echo "Setting ${NODE} log directory"
    sudo mkdir -m 0775 "/var/log/mariadb-multi/${NODE}" || exit $?
    sudo chown -R mysql:adm "/var/log/mariadb-multi/${NODE}" || exit $?
  fi
done

# See /lib/systemd/system/mariadb@.service
sudo echo -n > "multi-server-client.cnf"
for NODE in $NODES; do
  echo "Setting ${NODE} config..."
  NODE_ID=$(echo "${NODE}" | grep -Po '\d+$')
  sed -e "s/#NODE#/${NODE}/g;s/#NODE_ID#/${NODE_ID}/g;s/#NODE_SECTION#/${NODE}/g" "${BASE_DIR}/server-client-NODE.cnf" >> "multi-server-client.cnf" || exit $?
  sed -e "s/#NODE#/${NODE}/g;s/#NODE_ID#/${NODE_ID}/g;s/.#NODE_SECTION#//g" "${BASE_DIR}/server-client-NODE.cnf" > "${NODE}.cnf" || exit $?
  sudo cp "${NODE}.cnf" "/etc/mariadb-multi/" || exit $?
done
echo 'Setting combined config...'
sudo cp "multi-server-client.cnf" "/etc/mysql/mariadb.conf.d/20-multi-server-client.cnf" || exit $?

for NODE in $NODES; do
  if [ ! -f "/var/lib/mariadb-multi/${NODE}/ibdata1" ]; then
    echo "Installing ${NODE} instance..."
    if ! my_print_defaults --defaults-group-suffix=".${NODE}" --mariadbd | grep "/var/lib/mariadb-multi/${NODE}"; then
      echo "Group configuration test failed: group section config absent!";
      my_print_defaults --defaults-group-suffix=".${NODE}" --mariadbd
      exit 1
    fi
    if ! my_print_defaults --defaults-group-suffix=".${NODE}" --mariadbd | grep "/run/mariadb-multi/${NODE}"; then
      echo "Group configuration test failed: bogus stock config present!";
      my_print_defaults --defaults-group-suffix=".${NODE}" --mariadbd
      exit 1
    fi
    sudo -u mysql mariadb-install-db --user=mysql --defaults-group-suffix=".${NODE}" || exit $?
  fi
done

# TODO: AppArmor for mariadbd
# TODO: doesn't work without file-based /etc/systemd/system/mariadb@.service.d/multi.conf
for NODE in $NODES; do
  echo "Registering ${NODE} service..."
  sudo systemctl enable "mariadb@${NODE}.service" || exit $?
  echo "Starting ${NODE} service..."
  if ! sudo systemctl start "mariadb@${NODE}.service"; then
    CODE=$?
    sudo systemctl status "mariadb@${NODE}.service" --no-pager
    if [ -f "/var/log/mariadb-multi/${NODE}/error.log" ]; then
      echo ''
      sudo tail -n 30 "/var/log/mariadb-multi/${NODE}/error.log"
    fi
    exit $CODE
  fi
done
